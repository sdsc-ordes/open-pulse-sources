# Environment variables for open-pulse-sources.
# Copy to `.env` and fill in real values. `.env` is gitignored — never commit it.
# Anything left commented out falls back to the default shown.

# ---------------------------------------------------------------------------
# Service auth (required to serve the API)
# ---------------------------------------------------------------------------
# Bearer token guarding every route except `/` and `/health`. Fails closed:
# unset -> 503 on protected routes, wrong token -> 401. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
API_TOKEN=your-api-token-here

# ---------------------------------------------------------------------------
# Embeddings / rerank (required for embed pipelines and semantic search)
# ---------------------------------------------------------------------------
# EPFL RCP endpoint token (Qwen3-Embedding-8B / Qwen3-Reranker-8B). Without
# it, ingest into DuckDB still works but embed + /search return errors.
RCP_TOKEN=

# ---------------------------------------------------------------------------
# Infrastructure
# ---------------------------------------------------------------------------
# Qdrant endpoint. The compose stacks set this per-network; for a local
# process against a local Qdrant use http://localhost:6333.
# INDEX_QDRANT_URL=http://qdrant:6333

# Root for the per-index DuckDB stores (<INDEX_DATA_DIR>/<index>/...).
# Defaults to `data/index` under the *repo checkout* — ALWAYS set this
# explicitly in containers / wheel installs (e.g. /app/data/index), or the
# package-relative fallback resolves into site-packages.
# INDEX_DATA_DIR=data/index

# Selenium grid — only needed for Selenium-driven ingest (SWISSUbase, ORCID
# scraping). The compose stacks wire it to the bundled selenium service.
# SELENIUM_REMOTE_URL=

# Uvicorn worker count for the service image.
# WORKERS=1

# ---------------------------------------------------------------------------
# Per-source ingest tokens (only for the indices you actually ingest)
# ---------------------------------------------------------------------------
# GitHub REST (github_repos / github_users / github_organizations ingest).
GME_GITHUB_TOKEN=
# HF_TOKEN=                 # HuggingFace Hub (higher rate limits)
# INFOSCIENCE_TOKEN=        # protected Infoscience routes only
# GitLab tokens are PER INSTANCE (a generic GITLAB_TOKEN is not read).
# Optional for public projects/groups, but the *users* indices silently
# seed zero rows without one:
# GITLAB_EPFL_TOKEN=
# GITLAB_ETHZ_TOKEN=
# GITLAB_DATASCIENCE_TOKEN=
# ORCID_CLIENT_ID=          # ORCID public-API OAuth pair (orcid ingest)
# ORCID_CLIENT_SECRET=
# OPENALEX_MAILTO=          # OpenAlex polite-pool email (no key needed)
# ZENODO_TOKEN=             # optional; anonymous works with rate limits
# DOCKERHUB_TOKEN=          # optional; anonymous works with rate limits
# RENKULAB_TOKEN=           # richer RenkuLab user records (optional)
# EPFL_GRAPH_USERNAME=      # graphai.epfl.ch handshake (epfl_graph ingest only)
# EPFL_GRAPH_PASSWORD=

# ---------------------------------------------------------------------------
# Provider cache (names inherited from the monolith; rename planned pre-1.0)
# ---------------------------------------------------------------------------
# V2_PROVIDER_CACHE_PATH=.cache/v2/providers.db
# V2_PROVIDER_CACHE_TTL_DAYS=30
# V2_PROVIDER_CACHE_ENABLED=true
