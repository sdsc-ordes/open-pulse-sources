# Optional overrides for the devcontainer compose stack.
# Copy to `.devcontainer/.env` — only needed when the defaults collide with
# something else on your host (e.g. the GME devcontainer stack).

# Host ports
# SSH_PORT=2223            # sshd feature (internal 2222)
# APP_PORT=8080            # management API (just serve-dev)
# QDRANT_PORT=6333         # collides with GME's gme-qdrant — override if both run
# QDRANT_GRPC_PORT=6334
# SELENIUM_GRID_PORT=4444  # collides with GME's gme-selenium-firefox
# SELENIUM_VNC_PORT=7900

# DNS for the devcontainer (external networks sometimes lack a resolver)
# DEVCONTAINER_DNS_1=1.1.1.1
# DEVCONTAINER_DNS_2=8.8.8.8
